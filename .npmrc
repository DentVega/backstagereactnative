# GitHub Packages registry for the @dentvega scope (ADR-002).
# Replace @org with your real GitHub org/user and provide a token with read:packages
# (and write:packages in CI to publish) via the GITHUB_TOKEN env var.
@dentvega:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

# NOTE: do NOT enable `node-linker=hoisted` here. It flattens every dependency
# into the repo-root node_modules and leaves apps/host/node_modules almost empty,
# which breaks React Native's native build — android/settings.gradle resolves the
# RN gradle-plugin and react-native via the relative path ../node_modules/... and
# RNGP reads apps/host/node_modules/react-native/ReactAndroid/gradle.properties.
# The default isolated linker (symlinks + .pnpm store) is what makes both the
# native build and Re.Pack work. JS resolution gaps are handled by the
# public-hoist-pattern lines below plus explicit root devDependencies
# (@react-native/community-cli-plugin, @babel/plugin-syntax-typescript).
# node-linker=hoisted

# Module Federation runtime packages resolve sibling subpaths (@module-federation/
# error-codes/browser, runtime/helpers). Hoist the whole family to the top level so
# Rspack can resolve those export subpaths under pnpm.
public-hoist-pattern[]=@module-federation/*
public-hoist-pattern[]=@swc/helpers
